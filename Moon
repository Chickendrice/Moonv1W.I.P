<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Moon v1 Search</title>
<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Orbitron&display=swap" rel="stylesheet" />
<style>
  body {
    margin: 0;
    font-family: 'Orbitron', sans-serif;
    background: linear-gradient(135deg, #0d0d0d, #1a1a1a);
    color: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px;
  }

  body::before {
    content: "";
    position: fixed;
    top:0; left:0;
    width:100%; height:100%;
    background-image: radial-gradient(circle, #444 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.1;
    z-index: -1;
  }

  @keyframes sway {
    0% { transform: translateX(-10px); }
    50% { transform: translateX(10px); }
    100% { transform: translateX(-10px); }
  }

  #title {
    font-size: 4rem;
    margin-top: 50px;
    margin-bottom: 20px;
    color: #00ffff;
    text-shadow: 0 0 15px #00ffff, 0 0 30px #00ffff;
    animation: sway 3s infinite ease-in-out;
  }

  /* Search form styles */
  #search-form {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 600px;
    margin-bottom: 20px;
  }

  #search-input {
    padding: 1rem;
    font-size: 1.2rem;
    border-radius: 20px 0 0 20px;
    border: none;
    outline: none;
    width: 70%;
    max-width: 400px;
    background-color: #222;
    color: #fff;
  }

  #search-submit {
    padding: 1rem 2rem;
    font-size: 1.2rem;
    border: none;
    border-radius: 0 20px 20px 0;
    background-color: #00ffff;
    cursor: pointer;
    transition: background 0.3s;
  }

  #search-submit:hover {
    background-color: #00cccc;
  }

  /* Container for the "browser" window */
  #browser-container {
    display: none; /* Hidden initially */
    width: 100%;
    max-width: 900px;
    height: 70vh;
    border: 2px solid #00ffff;
    border-radius: 10px;
    box-shadow: 0 0 30px #00ffff, inset 0 0 10px #00ffff;
    overflow: hidden;
    flex-direction: column;
  }

  /* Header with back button */
  #browser-header {
    height: 40px;
    background: #333;
    display: flex;
    align-items: center;
    padding: 0 10px;
    border-bottom: 1px solid #00ffff;
  }

  #back-button {
    background-color: #00ffff;
    border: none;
    border-radius: 5px;
    padding: 5px 10px;
    cursor: pointer;
    font-family: 'Orbitron', sans-serif;
  }

  /* iframe for search results */
  #search-results {
    width: 100%;
    height: calc(100% - 40px);
    border: none;
  }
</style>
</head>
<body>

<h1 id="title">🌕 Moon v1</h1>

<!-- Search Form -->
<form id="search-form" onsubmit="return performSearch()">
  <div id="search-form-inner" style="display:flex; justify-content:center; width:100%; max-width:600px;">
    <input type="text" id="search-input" placeholder="Search the Moon..." required />
    <button type="submit" id="search-submit">🚀</button>
  </div>
</form>

<!-- Browser-like container for search results -->
<div id="browser-container">
  <div id="browser-header">
    <button id="back-button" onclick="showMain()">Back</button>
  </div>
  <iframe id="search-results" src=""></iframe>
</div>

<script>
  function performSearch() {
    const query = document.getElementById('search-input').value.trim();
    if (!query) return false;
    // Load search results in iframe
    document.getElementById('search-results').src = 'https://www.startpage.com/do/search?query=' + encodeURIComponent(query);
    // Show the browser container
    document.getElementById('browser-container').style.display = 'flex';
    // Hide the search form
    document.getElementById('search-form').style.display = 'none';
    return false; // prevent form from submitting
  }

  function showMain() {
    // Hide the search results container
    document.getElementById('browser-container').style.display = 'none';
    // Show the search form again
    document.getElementById('search-form').style.display = 'block';
  }
</script>

</body>
</html>  
